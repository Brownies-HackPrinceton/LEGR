# Public — exposed to the browser. Safe to commit as placeholders.
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:8000

# Optional: only used if you want to read directly from Supabase from the browser.
# Backend ingestion does NOT need these — the orchestrator uses SUPABASE_SERVICE_KEY.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Server-only — never use NEXT_PUBLIC_ prefix here.
# Used by Server Components and Route Handlers if/when we add them.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
