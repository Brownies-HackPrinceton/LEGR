NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Server-side (DO NOT expose these in client bundles)
DEDALUS_API_KEY=your_key
SUPABASE_URL=your_url
SUPABASE_SERVICE_KEY=your_service_key

# Photon Spectrum (iMessage delivery)
PHOTON_PROJECT_ID=your_project_id
PHOTON_SECRET_KEY=your_secret_key
# Use Photon cloud (default) or local Mac Messages DB:
# IMESSAGE_MODE=cloud
# IMESSAGE_MODE=local
# Include local node server if testing locally
IMESSAGE_FOUNDER_PHONE=+15551234567
IMESSAGE_BRIDGE_URL=http://127.0.0.1:3099

# RAG & Embeddings
OPENAI_API_KEY=your_openai_api_key

# Machine Agent Outbox (SMTP)
FLUX_EMAIL_ADDRESS=your-startup-address@gmail.com
FLUX_EMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx
